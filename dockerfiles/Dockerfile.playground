# User Playground Container
# Interactive environment with Ollama + vLLM support
# Base Path: /mnt/ai8_arch
# Author: CannonCoPilot
# Date: 2025-01-11

FROM nvidia/cuda:12.1.0-devel-ubuntu22.04

# Metadata
LABEL maintainer="CannonCoPilot"
LABEL description="Interactive playground for model experimentation"
LABEL version="1.0.0"

# Prevent interactive prompts
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    git \
    wget \
    vim \
    htop \
    tmux \
    software-properties-common \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install Python 3.11 (newer than Ubuntu 22.04 default)
RUN add-apt-repository ppa:deadsnakes/ppa && \
    apt-get update && \
    apt-get install -y \
        python3.11 \
        python3.11-dev \
    && rm -rf /var/lib/apt/lists/*

# Install pip for Python 3.11
RUN curl -sS https://bootstrap.pypa.io/get-pip.py | python3.11

# Set Python 3.11 as default
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1

# Verify Python
RUN python3 --version && pip3 --version

# Install Ollama (pinned version)
RUN curl -fsSL https://github.com/ollama/ollama/releases/download/v0.1.30/ollama-linux-amd64 \
    -o /usr/local/bin/ollama && \
    chmod +x /usr/local/bin/ollama

# Install vLLM and dependencies
# This takes 15-20 minutes due to CUDA compilation
RUN pip3 install --no-cache-dir \
    vllm \
    fastapi \
    uvicorn[standard] \
    transformers \
    accelerate \
    huggingface_hub \
    requests \
    sentence-transformers \
    langchain \
    langchain-community

# Install popular ML/AI libraries
RUN pip3 install --no-cache-dir \
    numpy \
    pandas \
    scikit-learn \
    matplotlib \
    jupyter

# Verify installations
RUN python3 -c "import vllm; print(f'vLLM version: {vllm.__version__}')" && \
    ollama --version

# Create helpful aliases
RUN echo 'alias ll="ls -lah"' >> /root/.bashrc && \
    echo 'alias gpu="nvidia-smi"' >> /root/.bashrc && \
    echo 'alias logs="tail -f /var/log/*.log"' >> /root/.bashrc

WORKDIR /app

# Expose ports
EXPOSE 11434 8000 8888

# Health check (checks if Ollama OR vLLM is running)
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:11434/api/tags || curl -f http://localhost:8000/health || exit 1

# Default command
CMD ["bash"]